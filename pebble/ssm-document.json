{
  "schemaVersion": "2.2",
  "description": "CSR Demo: Configure Nginx with new SSL certificate",
  "parameters": {
    "certPem": {
      "type": "String",
      "description": "PEM-encoded certificate"
    },
    "keyPem": {
      "type": "String",
      "description": "PEM-encoded private key"
    },
    "domain": {
      "type": "String",
      "description": "Domain name for the certificate"
    }
  },
  "mainSteps": [
    {
      "action": "aws:runShellScript",
      "name": "deployCertificate",
      "inputs": {
        "runCommand": [
          "set -e",
          "DOMAIN='{{domain}}'",
          "CERT_PATH=\"/etc/nginx/certs/${DOMAIN}.crt\"",
          "KEY_PATH=\"/etc/nginx/certs/${DOMAIN}.key\"",
          "CONF_PATH=\"/etc/nginx/conf.d/${DOMAIN}.conf\"",
          "mkdir -p /etc/nginx/certs",
          "echo '{{certPem}}' > \"$CERT_PATH\"",
          "echo '{{keyPem}}' > \"$KEY_PATH\"",
          "chmod 600 \"$KEY_PATH\"",
          "cat > \"$CONF_PATH\" << CONF",
          "server {",
          "    listen 443 ssl;",
          "    server_name ${DOMAIN};",
          "    ssl_certificate ${CERT_PATH};",
          "    ssl_certificate_key ${KEY_PATH};",
          "    ssl_protocols TLSv1.2 TLSv1.3;",
          "    location / {",
          "        return 200 'CSR Demo: ${DOMAIN} certificate is active';",
          "        add_header Content-Type text/plain;",
          "    }",
          "}",
          "CONF",
          "nginx -t && systemctl reload nginx",
          "echo 'Certificate deployed successfully for ${DOMAIN}'"
        ]
      }
    }
  ]
}
